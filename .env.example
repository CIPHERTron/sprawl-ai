# ── Copy to .env and fill in values before running ────────────────────────────
# Never commit .env — it is in .gitignore

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sprawl
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sprawl
DATABASE_URL=postgresql+asyncpg://sprawl:changeme@postgres:5432/sprawl

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── HashiCorp Vault (secret-zero — injected by operator, never committed) ──────
# Self-host: set these via `docker compose --env-file .env up`
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=          # AppRole role_id injected at runtime
VAULT_SECRET_ID=        # AppRole secret_id injected at runtime

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256

# ── GitHub App (filled in after GitHub App is created in M8) ─────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./infra/github/private-key.pem
GITHUB_WEBHOOK_SECRET=

# ── AWS (used in M9 for real connector; M5 uses sandbox fakes) ────────────────
AWS_REGION=us-east-1
AWS_ROLE_ARN=               # AssumeRole target ARN
AWS_EXTERNAL_ID=            # AssumeRole External ID

# ── LLM — LiteLLM provider (M7) ──────────────────────────────────────────────
# Default: Ollama (local, $0). Switch to a hosted model by setting LITELLM_MODEL.
LITELLM_MODEL=ollama/llama3.2
OLLAMA_BASE_URL=http://ollama:11434
# Opt-in hosted API (only needed if not using Ollama):
# LITELLM_API_KEY=sk-...

# ── Langfuse (agent tracing, M7) ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-web:3000

# ── Demo mode ─────────────────────────────────────────────────────────────────
DEMO_SESSION_TTL_SECONDS=3600
DEMO_RATE_LIMIT_PER_IP=10

# ── App ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ENVIRONMENT=development
LOG_LEVEL=INFO
